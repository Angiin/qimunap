---
import { storeUrl, price } from "../site";

const free = [
  "20-20-20 默认节奏",
  "小憩 + 长憩休息引导",
  "用眼数据统计",
  "智能免打扰",
  "浅色 / 深色主题",
];
const pro = ["免费版全部功能", "自定义小憩频率与时长", "后续 Pro 新功能", "感谢你的支持 💚"];
---

<section id="pricing" class="bg-section px-8 py-[clamp(44px,5.5vw,80px)]">
  <div class="mx-auto max-w-[920px]">
    <div class="text-center">
      <h2
        class="text-[clamp(28px,3.6vw,42px)] font-bold leading-[1.16] tracking-[-0.005em] text-ink-strong"
      >
        免费开始，喜欢再支持
      </h2>
      <p class="mx-auto mt-4 max-w-[560px] text-[clamp(16px,1.4vw,19px)] leading-[1.7] text-body-2">
        核心功能永久免费。Pro 是一次性买断，解锁自定义节奏，也是对开发的一份支持。
      </p>
    </div>
    <div
      class="mt-10 grid items-stretch gap-6"
      style="grid-template-columns:repeat(auto-fit,minmax(300px,1fr))"
    >
      <!-- 免费版 -->
      <div class="flex flex-col rounded-2xl border border-[#283c32]/10 bg-white px-[30px] py-[34px]">
        <div class="text-[15px] font-bold tracking-[.04em] text-muted-2">免费版</div>
        <div class="mt-3 text-[40px] font-bold text-ink-strong">¥0</div>
        <p class="mt-1.5 text-[14.5px] text-muted">完整的憩目体验</p>
        <ul class="mt-6 flex flex-1 list-none flex-col gap-[13px] p-0">
          {
            free.map((f) => (
              <li class="flex gap-2.5 text-[15.5px] text-body-3">
                <span class="text-brand">✓</span>
                {f}
              </li>
            ))
          }
        </ul>
        <a
          href={storeUrl}
          target="_blank"
          rel="noopener"
          class="mt-[26px] rounded-[10px] border-[1.5px] border-[#283c32]/20 px-6 py-3.5 text-center text-[16px] font-semibold text-ink transition-colors hover:bg-[#f0f3ec]"
          >免费下载</a
        >
      </div>
      <!-- Pro -->
      <div
        class="relative flex flex-col rounded-2xl border border-[#7fc3a9]/30 bg-pro-dark px-[30px] py-[34px] shadow-[0_30px_70px_-34px_rgba(20,45,36,.6)]"
      >
        <div
          class="absolute right-[26px] top-6 rounded-lg bg-[#ce9c5f]/[0.18] px-3 py-[5px] text-[12.5px] font-bold tracking-[.05em] text-[#e4b071]"
        >
          PRO
        </div>
        <div class="text-[15px] font-bold tracking-[.04em] text-brand-soft">憩目 Pro</div>
        <div class="mt-3 text-[40px] font-bold text-[#f1f5f1]">{price}</div>
        <p class="mt-1.5 text-[14.5px] text-[#9fb0a7]">一次性买断 · 永久解锁</p>
        <ul class="mt-6 flex flex-1 list-none flex-col gap-[13px] p-0">
          {
            pro.map((f) => (
              <li class="flex gap-2.5 text-[15.5px] text-[#d6e0d9]">
                <span class="text-brand-soft">✓</span>
                {f}
              </li>
            ))
          }
        </ul>
        <a
          href={storeUrl}
          target="_blank"
          rel="noopener"
          class="mt-[26px] rounded-[10px] bg-brand-soft px-6 py-3.5 text-center text-[16px] font-bold text-[#0c1619] transition-colors hover:bg-[#95d0ba]"
          >在 Microsoft Store 解锁</a
        >
      </div>
    </div>
  </div>
</section>
