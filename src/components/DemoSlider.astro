---
// 「看看它长什么样」——统计 / 憩目计划 / 通用 × 浅/深 截图切换器
---

<section id="demo" class="bg-section px-8 py-[clamp(44px,5.5vw,80px)]">
  <div class="mx-auto max-w-[1120px]">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <div class="text-[13.5px] font-bold uppercase tracking-[.1em] text-eyebrow">查看设置</div>
        <h2
          class="mt-2 text-[clamp(26px,3.2vw,38px)] font-bold leading-[1.16] tracking-[-0.005em] text-ink-strong"
        >
          看看它长什么样
        </h2>
        <p class="mt-2.5 text-[15.5px] text-muted">左右切换，浏览统计、憩目计划与通用设置。</p>
      </div>
      <div class="flex w-[220px] shrink-0 gap-1 rounded-[10px] bg-[#dce4d8] p-1" role="group" aria-label="主题">
        <button type="button" data-demo-theme="light" class="demo-seg" aria-pressed="true">浅色</button>
        <button type="button" data-demo-theme="dark" class="demo-seg" aria-pressed="false">深色</button>
      </div>
    </div>

    <div class="mt-6 flex items-center gap-[clamp(8px,1.6vw,18px)]">
      <button type="button" data-demo-prev aria-label="上一张" class="demo-arrow">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"></path></svg>
      </button>
      <div
        class="min-w-0 flex-1 overflow-hidden rounded-2xl border border-[#283c32]/10 shadow-[0_44px_90px_-34px_rgba(20,35,28,.5)]"
      >
        <img id="demoImg" src="/assets/stats-light.png" alt="憩目 应用界面" class="block w-full" />
      </div>
      <button type="button" data-demo-next aria-label="下一张" class="demo-arrow">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"></path></svg>
      </button>
    </div>

    <div class="mt-5 flex justify-center gap-2.5">
      <button type="button" data-demo-tab="stats" class="demo-dot" aria-pressed="true">统计</button>
      <button type="button" data-demo-tab="schedule" class="demo-dot" aria-pressed="false">憩目计划</button>
      <button type="button" data-demo-tab="general" class="demo-dot" aria-pressed="false">通用</button>
    </div>

    <div class="mt-7 text-center">
      <a
        href="/experience/"
        class="inline-flex items-center gap-2 rounded-[10px] bg-brand px-[22px] py-3 text-[15px] font-semibold text-white shadow-[0_10px_24px_-12px_rgba(47,125,110,.7)] transition-colors hover:bg-brand-dark"
      >
        打开完整交互体验
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
      </a>
      <p class="mt-2.5 text-[13px] text-muted-3">可拖滑块、切开关，还能试一次全屏憩屏</p>
    </div>
  </div>
</section>

<style>
  .demo-seg {
    flex: 1;
    padding: 9px 16px;
    border-radius: 8px;
    border: none;
    background: transparent;
    color: #607068;
    font-weight: 600;
    font-size: 15px;
    cursor: pointer;
    font-family: inherit;
    transition: 0.15s;
  }
  .demo-seg[aria-pressed="true"] {
    background: #fff;
    color: #1e2b26;
    font-weight: 700;
    box-shadow: 0 2px 8px -3px rgba(30, 45, 38, 0.3);
  }
  .demo-arrow {
    flex: 0 0 auto;
    width: 46px;
    height: 46px;
    border-radius: 999px;
    border: 1px solid rgba(40, 60, 50, 0.16);
    background: #fff;
    color: #2f7d6e;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 8px 20px -12px rgba(20, 35, 28, 0.4);
    transition: 0.15s;
  }
  .demo-arrow:hover { background: #f4f7f2; }
  .demo-dot {
    padding: 8px 16px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    font-family: inherit;
    background: #dce4d8;
    color: #54615a;
    transition: 0.15s;
  }
  .demo-dot[aria-pressed="true"] { background: #2f7d6e; color: #fff; }
</style>

<script>
  const tabs = ["stats", "schedule", "general"];
  let tab = "stats";
  let theme = "light";
  const img = document.getElementById("demoImg") as HTMLImageElement | null;

  function sync() {
    if (img) img.src = `/assets/${tab}-${theme}.png`;
    document
      .querySelectorAll<HTMLElement>("[data-demo-theme]")
      .forEach((b) => b.setAttribute("aria-pressed", String(b.dataset.demoTheme === theme)));
    document
      .querySelectorAll<HTMLElement>("[data-demo-tab]")
      .forEach((b) => b.setAttribute("aria-pressed", String(b.dataset.demoTab === tab)));
  }
  document.querySelectorAll<HTMLElement>("[data-demo-theme]").forEach((b) =>
    b.addEventListener("click", () => { theme = b.dataset.demoTheme!; sync(); })
  );
  document.querySelectorAll<HTMLElement>("[data-demo-tab]").forEach((b) =>
    b.addEventListener("click", () => { tab = b.dataset.demoTab!; sync(); })
  );
  document.querySelector("[data-demo-prev]")?.addEventListener("click", () => {
    tab = tabs[(tabs.indexOf(tab) + 2) % 3]; sync();
  });
  document.querySelector("[data-demo-next]")?.addEventListener("click", () => {
    tab = tabs[(tabs.indexOf(tab) + 1) % 3]; sync();
  });
  sync();
</script>
